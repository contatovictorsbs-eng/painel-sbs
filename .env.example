# Variáveis de ambiente — SBS Green Seeds
# Configure no Cloudflare Pages: Settings → Environment variables
#   (marque Production e Preview). Guia: backend/deploy-cloudflare.md
# NUNCA versione o arquivo .env real com as chaves preenchidas.

# --- Assistente IA (Groq) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- Clima & tempo ---
CLIMA_KEY=

# --- Cotações / preços de concorrentes ---
AV_KEY=

# --- Autenticação (login por perfil, server-side) ---
# AUTH_SECRET: segredo forte p/ assinar os tokens. OBRIGATÓRIO em produção.
# Use o valor entregue no handoff (48 bytes aleatórios). NÃO reaproveite este exemplo.
AUTH_SECRET=
# USERS_JSON: semente dos usuários (opcional — sem ela, usa a equipe SBS padrão).
# A senha vive na coleção `usuarios` (banco) e é TROCÁVEL por cada usuário.
# hash = sha256(senha + AUTH_SECRET). precisaTrocar=true força definir senha no 1º login.
# Para usuário de PARCEIRA, inclua "tenant":"<slug>" (isola os dados da parceira).
# Ex.: [{"email":"franca@sbsgreen.com.br","perfil":"marketing","nome":"França","hash":"...","precisaTrocar":true}]
USERS_JSON=

# --- Redefinição de senha (esqueci minha senha) ---
# Com RESEND_API_KEY, o código de 6 dígitos vai por e-mail; sem ela, aparece na tela (staging).
RESEND_API_KEY=
MAIL_FROM=SBS Green Seeds <nao-responder@sbsgreen.com.br>

# --- Banco de dados (obrigatório) ---
# Supabase/Postgres. Sem estas, o backend lança erro pedindo a configuração.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Integração CRM / ERP (vendas, vendedores) ---
ERP_TOKEN=

# --- Ambiente ---
# APP_ENV=producao | preview   (Cloudflare: produção = branch main; preview = demais branches/PRs)
